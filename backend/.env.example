# When running via Docker Compose, use the service name 'postgres' not 'localhost'
DATABASE_URL=postgresql://finance_user:finance_pass@postgres:5432/finance_db
SECRET_KEY=change-this-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: Override the allowed CORS origins (must be a JSON list structure if overridden)
# BACKEND_CORS_ORIGINS='["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:8000"]'
